# ==============================================================================
# LeadSense AI - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# MongoDB Connection String (Atlas or Local)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/leadsense-ai

# ------------------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------------------
# CRITICAL: Use a strong secret key (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# AWS Bedrock Configuration (REQUIRED)
# ------------------------------------------------------------------------------
# Get your long-term API key from AWS Bedrock Console
# Format: Base64-encoded bearer token
BEDROCK_API_KEY=your-bedrock-long-term-api-key-here
AWS_REGION=us-east-1

# ------------------------------------------------------------------------------
# AI Model Configuration
# ------------------------------------------------------------------------------
# Bedrock Model Options:
# - us.anthropic.claude-3-5-sonnet-20241022-v2:0 (Recommended - Best for production)
# - us.amazon.nova-lite-v1:0 (Fast and cheap)
# - us.amazon.nova-pro-v1:0 (More capable)
# - anthropic.claude-3-5-sonnet-20241022-v2:0 (Cross-region)
AI_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# AI Generation Parameters
AI_TEMPERATURE=0
AI_MAX_TOKENS=4000
AI_BATCH_SIZE=10
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY_MS=1000

# ------------------------------------------------------------------------------
# File Upload Configuration
# ------------------------------------------------------------------------------
# Max file size in bytes (default: 10MB = 10485760 bytes)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=.csv

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://leadsense-ai-frontend.onrender.com,https://leadsense-ai-admin.onrender.com

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
# Window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
# Log levels: error | warn | info | debug
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Development / Testing Options
# ------------------------------------------------------------------------------
# CRITICAL: Set to 'false' in production!
# Skips JWT authentication for development/testing
SKIP_AUTH=false

# ==============================================================================
# AWS Bedrock Setup Instructions:
# ==============================================================================
# 
# 1. Sign in to AWS Console: https://console.aws.amazon.com/bedrock/
# 
# 2. Select Region: us-east-1 (recommended)
# 
# 3. Enable Model Access:
#    - Navigate to: Model access → Manage model access
#    - Enable: Anthropic Claude 3.5 Sonnet v2
#    - Enable: Amazon Nova models (optional)
#    - Request access (usually instant approval)
# 
# 4. Create Long-Term API Key:
#    - Navigate to: Settings → API Keys
#    - Click "Create API Key"
#    - Copy the Base64-encoded key
#    - Paste into BEDROCK_API_KEY above
# 
# 5. Verify Access (AWS CLI):
#    aws bedrock list-foundation-models --region us-east-1
# 
# 6. Cost Estimates:
#    - Claude 3.5 Sonnet: $0.003 per 1K input tokens (very cheap!)
#    - Amazon Nova Lite: $0.00006 per 1K input tokens (cheapest)
#    - 1000 leads ≈ $0.30 - $1.50 depending on CSV complexity
#
# ==============================================================================

# ==============================================================================
# Production Deployment Checklist:
# ==============================================================================
# ✅ Set NODE_ENV=production
# ✅ Use a strong JWT_SECRET (32+ characters)
# ✅ Configure production MongoDB URI (MongoDB Atlas recommended)
# ✅ Set SKIP_AUTH=false
# ✅ Configure appropriate CORS_ORIGIN
# ✅ Set LOG_LEVEL=warn or error
# ✅ Enable rate limiting with appropriate limits
# ✅ Use HTTPS for all origins
# ✅ Verify AWS Bedrock API key is valid
# ✅ Test import with sample CSV before launch
# ==============================================================================
